{
  "name": "discord-app-bot",
  "version": "0.7.1",
  "private": true,
  "description": "A Discord bot for automating the handling of Google Forms pushed to a server.",
  "license": "MIT",
  "author": {
    "name": "Adam Langbert",
    "email": "adamhl@pm.me",
    "url": "https://github.com/adamhl8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adamhl8/discord-app-bot"
  },
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "markdown-toc -i --bullets '-' --maxdepth 3 ./README.md && oxfmt && oxlint --fix --fix-suggestions --fix-dangerously && adamhl8-knip",
    "bump-deps": "nub update -L && rm -f lock.yaml && nub i && oxfmt lock.yaml && nub run db:generate",
    "bundle": "nub run lint",
    "release": "gh workflow run release.yml",
    "release:run": "release-it --ci -i \"$(adamhl8-cliff --bumped-version)\"",
    "prepare": "lefthook install",
    "start:prod": "prisma migrate deploy && nub ./src/index.ts"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sindresorhus/slugify": "^3.0.0",
    "discord-bot-shared": "^0.16.2",
    "discord.js": "^14.26.4",
    "get-urls": "^12.1.0",
    "prisma": "^7.8.0",
    "ts-explicit-errors": "^4.1.2",
    "type-fest": "^5.7.0"
  },
  "devDependencies": {
    "@adamhl8/configs": "^0.24.12",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "knip": "^6.24.0",
    "markdown-toc": "^1.2.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "release-it": "^20.2.1",
    "typescript": "^6.0.3"
  }
}
